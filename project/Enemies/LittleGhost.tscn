[sub_resource type="GDScript" id="GDScript_yda8n"]
script/source = "extends State

var idle_timer : Timer
var slot_timer : Timer

signal disable_hitbox()

func _ready():
	idle_timer = Timer.new()
	add_child(idle_timer)
	idle_timer.one_shot = true
	idle_timer.timeout.connect(_idle_timeout)
	
	slot_timer = Timer.new()
	add_child(slot_timer)
	slot_timer.timeout.connect(_slot_timeout)

func _enter_state():
	change_animation.emit(\"idle\")
	actor.velocity = Vector2.ZERO
	var time_to_idle = randi_range(3,7)
	idle_timer.start(time_to_idle)
	slot_timer.start(0.5)
	
	disable_hitbox.emit()
	
	
func _exit_state():
	idle_timer.stop()
	slot_timer.stop()

func _physics_update(delta):
	apply_gravity(actor, delta)
	check_falling()
	apply_friction(actor, delta)

func check_falling():
	if ! actor.is_on_floor():
		change_state.emit('fall')

func _idle_timeout():
	if actor.in_player_range:
		change_state.emit('slotting')
	else:
		change_state.emit('wander')
		
func _slot_timeout():
	if actor.in_player_range:
		change_state.emit('slotting')
"

[sub_resource type="GDScript" id="GDScript_sranb"]
script/source = "extends State

var direction
var target_pos
var current_pos

# Called when the node enters the scene tree for the first time.
func _ready() -> void:
	pass # Replace with function body.

# Called every frame. 'delta' is the elapsed time since the previous frame.
func _enter_state():
	change_animation.emit(\"walk\")
	target_pos = actor.target_pos
	
func _exit_state():
	pass
	
func _physics_update(delta):
	target_pos = actor.target_pos
	current_pos = actor.global_position
	direction = current_pos.direction_to(actor.target_pos)
	actor.new_direction = direction.x

	current_pos = actor.global_position
	apply_gravity(actor, delta)

	var distance = abs(current_pos.x - target_pos.x)

	if distance > 1.0:
		var target_velocity = direction * actor.SPEED
		actor.velocity = actor.velocity.move_toward(target_velocity, actor.ACCELLERATION * delta)
	else:
		change_state.emit('slotted')
	
	actor.move_and_slide()
"

[sub_resource type="GDScript" id="GDScript_mi5c5"]
script/source = "extends State

var direction
var target_pos
var current_pos
var player_pos

var jump_timer : Timer


signal get_player_pos(requester: Node)

func _ready():
	jump_timer = Timer.new()
	add_child(jump_timer)
	jump_timer.timeout.connect(try_attack)

# Called every frame. 'delta' is the elapsed time since the previous frame.
func _enter_state():
	get_player_pos.emit(self)
	change_animation.emit(\"idle\")
	target_pos = actor.target_pos
	current_pos = actor.global_position
	direction = current_pos.direction_to(player_pos)
	actor.new_direction = direction.x
	
	jump_timer.start(2)
	
func _exit_state():
	jump_timer.stop()
	
func _physics_update(delta):
	apply_friction(actor, delta)
	apply_gravity(actor, delta)
	
	current_pos = actor.global_position

	var distance = abs(current_pos.x - actor.target_pos.x)
	
	if !actor.in_player_range:
		change_state.emit('idle')
	elif distance > 5.0:
		change_state.emit('slotting')
	
	actor.move_and_slide()

func _catch_player_pos(new_pos):
	player_pos = new_pos

func try_attack():
	if actor.target_slot == actor.target_slot:
		change_state.emit('jump')
"

[sub_resource type="GDScript" id="GDScript_d3ij5"]
script/source = "extends State

func _enter_state():
	change_animation.emit(\"fall\")
	
func _physics_update(delta):
	if actor.is_on_floor():
		change_state.emit(\"land\")
	apply_gravity(actor, delta)
"

[sub_resource type="GDScript" id="GDScript_65eol"]
script/source = "extends State

const LAND_TIME = 0.2
var land_timer : Timer
@export var Actor : Node2D

signal disable_hitbox()

func _ready():
	land_timer = Timer.new()
	add_child(land_timer)
	land_timer.one_shot = true
	land_timer.timeout.connect(_on_land)

func _enter_state():
	change_animation.emit(\"land\")
	disable_hitbox.emit()
	actor.velocity = Vector2.ZERO
	land_timer.start(LAND_TIME)
	
func _exit_state():
	land_timer.stop()

func _on_land():
	change_state.emit(\"idle\")
"

[sub_resource type="GDScript" id="GDScript_wj2sv"]
script/source = "extends State

func _enter_state():
	change_animation.emit(\"load\")
	actor.velocity = Vector2.ZERO
	var load_timer = randf_range(0.2, 1.0)
	await get_tree().create_timer(load_timer).timeout
	change_state.emit(\"jump\")

func _physics_update(delta):
	apply_gravity(actor, delta)
	apply_friction(actor, delta)
"

[sub_resource type="GDScript" id="GDScript_aq2f5"]
script/source = "extends State

@export var hitbox : CollisionShape2D
signal enable_hitbox()

func _enter_state():
	change_animation.emit(\"jump\")
	actor.velocity.x += (actor.JUMP_LENGTH * actor.current_direction)
	actor.velocity.y -= actor.JUMP_HEIGHT
	
	enable_hitbox.emit()


func _physics_update(delta):
	if actor.velocity.y >= 0:
		change_state.emit(\"fall\")
	apply_gravity(actor, delta)
"

[sub_resource type="GDScript" id="GDScript_x5eyo"]
script/source = "extends RayCast2D

@export var actor: CharacterBody2D
var target_pos : Vector2
var start_pos : Vector2

# Called every frame. 'delta' is the elapsed time since the previous frame.
func _process(delta: float) -> void:
	global_position = start_pos
	target_position = target_pos - start_pos
"

