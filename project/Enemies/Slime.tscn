[sub_resource type="GDScript" id="GDScript_fg8f5"]
script/source = "extends State

@export var playerDetection : Node

func _enter_state():
	print(\"--- Actor: %s ---\" % [actor])
	change_animation.emit(\"idle\")
	actor.velocity = Vector2.ZERO


func _physics_update(delta):
	apply_gravity(actor, delta)
	if playerDetection.has_overlapping_bodies():
		var bodies = playerDetection.get_overlapping_bodies()
		if bodies[0] is Player && actor.ready_to_chase:
			change_state.emit(\"chase\")
	check_falling()
	apply_friction(actor, delta)


func check_falling():
	if ! actor.is_on_floor():
		change_state.emit('fall')
"

[sub_resource type="GDScript" id="GDScript_ab4al"]
script/source = "extends State

"

[sub_resource type="GDScript" id="GDScript_8jn37"]
script/source = "extends State

@export var attackZone : Node

func _enter_state():
	change_animation.emit(\"walk\")

func _physics_update(delta):
	var direction = (player.global_position - actor.global_position).normalized()
	actor.new_direction = direction.x
	actor.velocity.x = move_toward(actor.velocity.x, direction.x * actor.SPEED, actor.ACCELLERATION * delta)
	if attackZone.has_overlapping_bodies():
		var bodies = attackZone.get_overlapping_bodies()
		if bodies[0] is Player && actor.ready_to_attack:
			change_state.emit(\"load\")
	apply_gravity(actor, delta)
	apply_friction(actor, delta)
	check_falling()
	

func check_falling():
	if ! actor.is_on_floor():
		change_state.emit('fall')

"

[sub_resource type="GDScript" id="GDScript_1wkja"]
script/source = "extends State

func _enter_state():
	change_animation.emit(\"load\")
	actor.velocity = Vector2.ZERO
	var load_timer = randf_range(0.2, 1.0)
	await get_tree().create_timer(load_timer).timeout
	change_state.emit(\"jump\")

func _physics_update(delta):
	apply_gravity(actor, delta)
	apply_friction(actor, delta)
"

[sub_resource type="GDScript" id="GDScript_rx3qd"]
script/source = "extends State

func _enter_state():
	change_animation.emit(\"jump\")
	actor.velocity.x += (actor.JUMP_LENGTH * actor.current_direction)
	actor.velocity.y -= actor.JUMP_HEIGHT

func _physics_update(delta):
	if actor.velocity.y >= 0:
		change_state.emit(\"fall\")
	apply_gravity(actor, delta)
"

[sub_resource type="GDScript" id="GDScript_r0pip"]
script/source = "extends State

func _enter_state():
	change_animation.emit(\"fall\")
	
func _physics_update(delta):
	if actor.is_on_floor():
		change_state.emit(\"land\")
	apply_gravity(actor, delta)
"

[sub_resource type="GDScript" id="GDScript_hfxt2"]
script/source = "extends State

const FRICTION = 200

func _enter_state():
	change_animation.emit(\"recover\")

func _physics_update(delta):
	if actor.velocity.x == 0:
		change_state.emit(\"idle\")
	apply_friction(actor, delta)
	apply_gravity(actor, delta)

func apply_friction(actor, delta):
	actor.velocity.x = move_toward(actor.velocity.x, 0, FRICTION * delta)
"

[sub_resource type="GDScript" id="GDScript_6wghi"]
script/source = "extends State

const LAND_TIMER = 0.2

func _enter_state():
	change_animation.emit(\"land\")
	actor.velocity = Vector2.ZERO
	await get_tree().create_timer(LAND_TIMER).timeout
	actor.ready_to_chase = false
	actor.ready_to_attack = false
	change_state.emit(\"idle\")
	
"

[sub_resource type="GDScript" id="GDScript_0nphp"]
script/source = "extends State

func _enter_state():
	actor.velocity = Vector2.ZERO
	change_animation.emit(\"death\")
	await get_tree().create_timer(1).timeout
	actor.queue_free()
	
"

