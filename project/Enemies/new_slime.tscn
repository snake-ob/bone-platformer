[sub_resource type="GDScript" id="GDScript_qhwpm"]
script/source = "extends State

# Called when the node enters the scene tree for the first time.
func _ready() -> void:
	pass # Replace with function body.

# Called every frame. 'delta' is the elapsed time since the previous frame.
func _enter_state():
	pass

func _exit_state():
	pass
	
func _physics_update(delta):
	var target_pos: Vector2 = actor.target_position
	var current_pos: Vector2 = actor.current_pos

	var direction = current_pos.direction_to(target_pos)
	var distance = current_pos.distance_to(target_pos)

	if distance > 5.0:
		var target_velocity = direction * actor.SPEED
		actor.velocity = actor.velocity.move_toward(target_velocity, actor.ACCELERATION * delta)
	else:
		actor.velocity = actor.velocity.move_toward(Vector2.ZERO, actor.FRICTION * delta)
	
	actor.move_and_slide()
"

