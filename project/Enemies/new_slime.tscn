[sub_resource type="GDScript" id="GDScript_ws8b7"]
script/source = "extends Area2D

@export var Actor : Node
const POWER = 200
const DAMAGE = 1

func _on_body_entered(body):
	var direction = (body.global_position - Actor.global_position).normalized()
	var force = direction * POWER
	if body is RigidBody2D:
		body.interacted(force)
	elif body is Enemy:
		body.apply_knockback()

func _on_area_entered(area):
	var direction = (area.global_position - Actor.global_position).normalized()
	var force = direction * POWER
	if area is HurtBox:
		area.taken_hit(force, DAMAGE)
		print(\"Flag 2\")
	print(\"Flag 1\")
"

