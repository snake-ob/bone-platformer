[sub_resource type="GDScript" id="GDScript_holk3"]
script/source = "extends State

@export var Actor : Node

func _enter_state():
	if Actor:
		Actor.velocity = Vector2.ZERO
	change_animation.emit(\"idle\")

func _physics_update(delta):
	apply_gravity(Actor, delta)
	apply_friction(Actor, delta)
	
	var input = Vector2.ZERO
	input.x = Input.get_axis(\"ui_left\", \"ui_right\")
	input.y = Input.get_axis(\"ui_down\", \"ui_up\")
	
	if input.x != 0:
		Actor.new_direction = input.x
		change_state.emit(\"walk\")
	if input.y < 0:
		change_state.emit(\"crouch\")

	check_jumping()
	check_punching()
	
	if not Actor.is_on_floor():
		change_state.emit(\"fall\")
	
func process_punch():
	if Actor.cross_ready == true:
		change_state.emit(\"cross\")
	elif Input.is_action_pressed(\"ui_up\"):
		change_state.emit(\"uppercut\")
	else:
		change_state.emit(\"jab\")
	
"

[sub_resource type="GDScript" id="GDScript_cq87p"]
script/source = "extends State

@export var Actor : Node

func _enter_state():
	change_animation.emit('walk')
	if Actor:
		Actor.velocity = Vector2.ZERO
	
func _physics_update(delta):
	apply_gravity(Actor, delta)
	
	var input = Vector2.ZERO
	input.x = Input.get_axis(\"ui_left\", \"ui_right\")
	input.y = Input.get_axis(\"ui_down\", \"ui_up\")
	
	if input.x != 0:
		move_direction(delta, input)
	
	if input.x == 0:
		change_state.emit(\"idle\")
	if input.y < 0:
		change_state.emit(\"crouch\")
		
	check_jumping()
	check_punching()
	
	if not Actor.is_on_floor():
		change_state.emit(\"fall\")

func move_direction(delta, input):
	if Actor:
		Actor.velocity.x = move_toward(Actor.velocity.x, Actor.SPEED * input.x, Actor.ACCELLERATION)

func process_punch():
	if Actor.cross_ready == true:
		change_state.emit(\"cross\")
	elif Input.is_action_pressed(\"ui_up\"):
		change_state.emit(\"uppercut\")
	else:
		change_state.emit(\"jab\")
"

[sub_resource type="GDScript" id="GDScript_xfc0g"]
script/source = "extends State

@export var Actor : Node

func _enter_state():
	if Actor:
		Actor.velocity = Vector2.ZERO
	change_animation.emit(\"crouch\")

func _physics_update(delta):
	apply_gravity(Actor, delta)
	var input = Vector2.ZERO
	input.x = Input.get_axis(\"ui_left\", \"ui_right\")
	input.y = Input.get_axis(\"ui_up\", \"ui_down\")
	if input.x != 0 && input.y <= 0:
		change_state.emit(\"walk\")
	if input.y <= 0:
		change_state.emit(\"idle\")
		
	check_punching()

func process_punch():
	change_state.emit(\"crouchjab\")
"

[sub_resource type="GDScript" id="GDScript_lk3wb"]
script/source = "extends State

@export var Actor : Node

var fast_fell : bool

func _enter_state():
	fast_fell = false
	Actor.velocity.y -= Actor.JUMP_FORCE
	change_animation.emit(\"jump\")

func _physics_update(delta):
	apply_gravity(Actor, delta)
	
	if not Input.is_action_pressed(\"ui_jump\"):
		if Actor.velocity.y < 0 && Actor.velocity.y > -100:
			change_state.emit(\"fall\")
	if Actor.velocity.y >= 0:
		change_state.emit(\"fall\")
	
	var input = Vector2.ZERO
	input.x = Input.get_axis(\"ui_left\", \"ui_right\")
	input.y = Input.get_axis(\"ui_down\", \"ui_up\")
	
	if input.x != 0:
		Actor.new_direction = input.x
		move_direction(delta, input)
	
	if Input.is_action_just_pressed(\"ui_punch\"):
		process_aerial()
	
func move_direction(delta, input):
	if Actor:
		Actor.velocity.x = move_toward(Actor.velocity.x, Actor.SPEED * input.x, Actor.ACCELLERATION)
	
func process_aerial():
	if Input.is_action_pressed(\"ui_down\"):
		change_state.emit(\"downaerial\")
	if Input.is_action_pressed(\"ui_up\"):
		change_state.emit(\"upaerial\")
"

[sub_resource type="GDScript" id="GDScript_7h0ag"]
script/source = "extends State

@export var Actor : Node
@export var wallRaycastL : Node
@export var wallRaycastR : Node

func _enter_state():
	if Actor.velocity.y < 0:
		Actor.velocity.y = 0
	change_animation.emit(\"jump\")

func _physics_update(delta):
	apply_strong_gravity(Actor, delta)
	
	var input = Vector2.ZERO
	input.x = Input.get_axis(\"ui_left\", \"ui_right\")
	input.y = Input.get_axis(\"ui_down\", \"ui_up\")
	
	if input.x != 0:
		Actor.new_direction = input.x
		move_direction(delta, input)
	
	
	if Actor.is_on_floor():
		change_state.emit(\"idle\")
	
	if Input.is_action_just_pressed(\"ui_punch\"):
		process_aerial()
		
	if Actor.is_on_wall():
		if wallRaycastL.is_colliding() && Input.is_action_pressed(\"ui_left\"):
			change_state.emit(\"wallslide\")
		elif wallRaycastR.is_colliding() && Input.is_action_pressed(\"ui_right\"):
			change_state.emit(\"wallslide\")
		
func apply_strong_gravity(actor, delta):
	actor.velocity.y += actor.STRONG_GRAVITY * delta
	
func move_direction(delta, input):
	if Actor:
		Actor.velocity.x = move_toward(Actor.velocity.x, Actor.AERIAL_SPEED * input.x, Actor.ACCELLERATION)
	
func process_aerial():
	if Input.is_action_pressed(\"ui_down\"):
		change_state.emit(\"downaerial\")
"

[sub_resource type="GDScript" id="GDScript_2330s"]
script/source = "extends State

@export var Actor : Node
@export var HitBox : Node

func _enter_state():
	change_animation.emit(\"crouch_jab\")
	HitBox.set_disabled(false)
	await get_tree().create_timer(Actor.JAB_TIME).timeout
	_on_jab_finished()

func _exit_state():
	HitBox.set_disabled(true)

func _on_jab_finished():
	change_state.emit(\"crouch\")

"

[sub_resource type="GDScript" id="GDScript_hb3du"]
script/source = "extends State

@export var Actor : Node
@export var HitBox : Node
var punch_held : bool

func _enter_state():
	HitBox.set_disabled(false)
	punch_held = true
	if Actor:
		Actor.velocity = Actor.velocity/4
	change_animation.emit(\"jab\")
	await get_tree().create_timer(Actor.JAB_TIME).timeout
	Actor.cross_ready = true
	_on_jab_finished()

func _exit_state():
	HitBox.set_disabled(true)

func _physics_update(delta):
	if Input.is_action_just_released(\"ui_punch\"):
		punch_held = false

func _on_jab_finished():
	if Input.is_action_pressed(\"ui_punch\") && punch_held:
		change_state.emit(\"powercross\")
	else:
		change_state.emit(\"idle\")
"

[sub_resource type="GDScript" id="GDScript_vl204"]
script/source = "extends State

@export var Actor : Node
@export var HitBox : Node
var punch_held : bool

func _enter_state():
	HitBox.set_disabled(false)
	punch_held = true
	if Actor:
		Actor.velocity = Actor.velocity/2
		Actor.cross_ready = false
	change_animation.emit(\"cross\")
	await get_tree().create_timer(Actor.CROSS_TIME).timeout
	_on_cross_finished()

func _exit_state():
	HitBox.set_disabled(true)
	
func _physics_update(delta):
	if Input.is_action_just_released(\"ui_punch\"):
		punch_held = false

func _on_cross_finished():
	if Input.is_action_pressed(\"ui_punch\") && punch_held:
		change_state.emit(\"hook\")
	else:
		change_state.emit(\"idle\")
"

[sub_resource type="GDScript" id="GDScript_cw3vx"]
script/source = "extends State

@export var Actor : Node
@export var HitBox : Node
@export var FORWARD_FORCE = 100
@export var FRICTION = 400

func _enter_state():
	HitBox.set_disabled(false)
	if Actor:
		Actor.velocity.x += (FORWARD_FORCE * Actor.current_direction)
	change_animation.emit(\"power_cross\")

func _exit_state():
	HitBox.set_disabled(true)
	

func _on_animated_sprite_2d_animation_finished():
	change_state.emit(\"idle\")

func _physics_update(delta):
	Actor.velocity.x = move_toward(Actor.velocity.x, 0, FRICTION * delta)
	
"

[sub_resource type="GDScript" id="GDScript_ug7xa"]
script/source = "extends State

@export var Actor : Node
@export var HitBox : Node
@export var FORWARD_FORCE = 80
@export var FRICTION = 400

func _enter_state():
	HitBox.set_disabled(false)
	if Actor:
		Actor.velocity.x += (FORWARD_FORCE * Actor.current_direction)
	change_animation.emit(\"hook\")

func _exit_state():
	HitBox.set_disabled(true)
	
func _on_animated_sprite_2d_animation_finished():
	change_state.emit(\"idle\")

func _physics_update(delta):
	Actor.velocity.x = move_toward(Actor.velocity.x, 0, FRICTION * delta)
"

[sub_resource type="GDScript" id="GDScript_e0m6j"]
script/source = "extends State

@export var Actor : Node
@export var HitBox : Node

func _enter_state():
	HitBox.set_disabled(false)
	change_animation.emit(\"down_aerial\")
	await get_tree().create_timer(Actor.CROSS_TIME).timeout
	if Actor.velocity.y >= 0:
		change_state.emit(\"fall\")

func _exit_state():
	HitBox.call_deferred(\"set_disabled\", true)
	
func _physics_update(delta):
	apply_gravity(Actor, delta)

func _on_aerial_down_body_entered(body):
	change_state.emit(\"pogo\")

func _on_aerial_down_area_entered(area):
	change_state.emit(\"pogo\")
"

[sub_resource type="GDScript" id="GDScript_fnkjj"]
script/source = "extends State

@export var Actor : Node
@export var HitBox : Node

func _enter_state():
	HitBox.set_disabled(false)
	change_animation.emit(\"up_aerial\")
	await get_tree().create_timer(Actor.CROSS_TIME).timeout
	_on_aerial_finished()

func _exit_state():
	HitBox.set_disabled(true)
	
func _physics_update(delta):
	apply_gravity(Actor, delta)

func _on_aerial_finished():
	change_state.emit(\"fall\")
"

[sub_resource type="GDScript" id="GDScript_uwhvp"]
script/source = "extends State

@export var Actor : Node
var SLIDE_SPEED = 1

func _enter_state():
	SLIDE_SPEED = 1
	swap_directions()
	Actor.velocity = Vector2.ZERO
	change_animation.emit(\"wallslide\")

func _physics_update(delta):
	SLIDE_SPEED = SLIDE_SPEED * (delta * 2 + 1)
	slide_down()
	if Input.is_action_just_pressed(\"ui_jump\"):
		Actor.velocity.x += Actor.WALL_JUMP_FORCE * Actor.current_direction
		Actor.velocity.y = Actor.velocity.y /2
		change_state.emit(\"walljump\")
	if Actor.is_on_floor():
		change_state.emit(\"idle\")
	
func swap_directions():
	if Actor.velocity.x == 0:
		Actor.new_direction = Actor.current_direction * -1
	else:
		Actor.new_direction = Actor.velocity.x * -1
		

func slide_down():
	Actor.velocity.y += SLIDE_SPEED
"

[sub_resource type="GDScript" id="GDScript_gcesf"]
script/source = "extends State

@export var Actor : Node

func _enter_state():
	Actor.velocity.y -= Actor.JUMP_FORCE
	change_animation.emit(\"jump\")

func _physics_update(delta):
	apply_gravity(Actor, delta)
	
	if Actor.velocity.y >= 0:
		change_state.emit(\"fall\")
	
	if Input.is_action_just_pressed(\"ui_punch\"):
		process_aerial()
	
func process_aerial():
	if Input.is_action_pressed(\"ui_up\"):
		change_state.emit(\"upaerial\")
	if Input.is_action_pressed(\"ui_down\"):
		change_state.emit(\"downaerial\")
"

[sub_resource type="GDScript" id="GDScript_tpd5w"]
script/source = "extends State

@export var Actor : Node

func _enter_state():
	Actor.velocity.y = 0
	change_animation.emit(\"pogo\")
	Actor.velocity.y -= Actor.JUMP_FORCE

func _physics_update(delta):
	apply_gravity(Actor, delta)
	
	if Actor.velocity.y >= 0:
		change_state.emit(\"fall\")
	
	var input = Vector2.ZERO
	input.x = Input.get_axis(\"ui_left\", \"ui_right\")
	input.y = Input.get_axis(\"ui_down\", \"ui_up\")
	
	if input.x != 0:
		move_direction(delta, input)
	
func move_direction(delta, input):
	if Actor:
		Actor.velocity.x = move_toward(Actor.velocity.x, Actor.AERIAL_SPEED * input.x, Actor.ACCELLERATION)
"

[sub_resource type="GDScript" id="GDScript_8g4oa"]
script/source = "extends State

@export var UPPERCUT_VELOCITY = 400

@export var Actor : Node
@export var HitBox : Node
var punch_held : bool

var uppercut_timer : Timer

func _ready():
	uppercut_timer = Timer.new()
	add_child(uppercut_timer)
	uppercut_timer.one_shot = true
	uppercut_timer.timeout.connect(_on_uppercut_finished)

func _enter_state():
	HitBox.set_disabled(false)
	punch_held = true
	if Actor:
		Actor.velocity.x = Actor.velocity.x/2
		Actor.velocity.y -= UPPERCUT_VELOCITY
	change_animation.emit(\"uppercut\")
	#uppercut_timer.start(2)

func _physics_update(delta):
	if Actor.velocity.y >= 0:
		change_state.emit('fall')
	apply_gravity(Actor, delta)

func _exit_state():
	HitBox.set_disabled(true)
	uppercut_timer.stop()

func _on_uppercut_finished():
	if Actor.velocity.y !=0:
		change_state.emit(\"fall\")
	else:
		change_state.emit(\"idle\")
"

