resource_name = "Level"
script/source = "extends Node2D

var current_player_tile

func _ready() -> void:
	$Player.new_tile_entered.connect(_on_player_new_tile)
	$QueueManager.slots_updated.connect(_on_slots_updated)

# Called every frame. 'delta' is the elapsed time since the previous frame.
func _process(delta: float) -> void:
	pass

func _on_player_new_tile(new_tile, tilemap):
	$QueueManager.refresh_tiles(new_tile, tilemap)
	
func _on_slots_updated(slots):
	$EnemyManager._catch_slots(slots)
	
"

[sub_resource type="GDScript" id="GDScript_e6i1n"]
script/source = "extends Node2D
#This is a Node2D so that we can debug slot positions

class Slot:
	var active: bool = false
	var held_by: Enemy = null
	var reserved_by: Enemy = null
	var centre: Vector2
	var pos_index: int = 0
	
	func is_available():
		return held_by == null and reserved_by == null
		
	func _to_string():
		return \"Slot(index:%d, x:%d, y:%d)\" % [pos_index, centre.x, centre.y]
		
var slots: Array

signal slots_updated(slots)

func _draw():
	for slot in slots:
		var draw_pos = Vector2(slot.centre) - global_position
		draw_circle(draw_pos, 5.0, Color.INDIAN_RED)

func _ready():
	for i in range(-3,4):
		if i == 0: continue
		var new_slot = Slot.new()
		new_slot.pos_index = i
		slots.append(new_slot)
	print(slots)

func refresh_tiles(new_tile :Vector2i, tile_map: TileMapLayer):
	var centre_tile_pos = tile_map.to_global(tile_map.map_to_local(new_tile))
	var tile_width = tile_map.tile_set.tile_size.x
	
	for slot in slots:
		var offset_x = slot.pos_index * tile_width
		slot.centre.x = centre_tile_pos.x + offset_x
		slot.centre.y = centre_tile_pos.y
		
	queue_redraw()
	slots_updated.emit(slots)
"

[sub_resource type="GDScript" id="GDScript_tnerh"]
script/source = "extends Node

var slots: Array

# Keeps track of all enemy positions close to player
# Gives each enemy a slot target on queue refresh
# Loops through enemy, from closest to farthest, and assigns them
# a slot target (depending on slot availability)

# Assigns enemies to their 'active' spot.
# If they don't have one, they are added to a waiting list to wait
# behind the active spot. If no enemy has that active spot reserved
# after assigning. They will be assigned to their waiting spot
# (this will form a line where they wait for the next enemy to
# get out of the way)

func _catch_slots(new_slots: Array):
	# QueueManager will pass new slots every update
	if new_slots:
		slots = new_slots
"

