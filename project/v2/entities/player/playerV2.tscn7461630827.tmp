[sub_resource type="GDScript" id="GDScript_7atpg"]
script/source = "extends State

func _enter_state():
	actor.velocity.x = 0

func _physics_update(delta):
	if not actor.is_on_floor():
		change_state.emit(\"fall\")
	if ref.input.is_crouching:
		change_state.emit(\"crouch\")
	if ref.input.consume_jump():
		change_state.emit(\"jump\")
	
	var attack = ref.input.consume_punch()
	if attack.requested:
		process_punch()
	
func _setup(p_actor, p_data):
	actor = p_actor
	ref = p_data

func process_punch():
	pass
"

